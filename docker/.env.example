# ─── ChromaDB Docker Config ──────────────────────────────────────────────────
# Puerto expuesto (default: 8000)
CHROMA_PORT=8000

# Autenticación por token (dejar vacío para desactivar)
# Para activar, descomentar ambas líneas:
# CHROMA_AUTH_TOKEN=mi-token-secreto
# CHROMA_AUTH_PROVIDER=chromadb.auth.token_authn.TokenAuthenticationServerProvider
